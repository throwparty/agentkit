use flake ./nix
watch_dir ./nix

bitwarden_org=d76a483e-3e70-450d-b7d0-b3a9015fa410
repo=throwparty/agentkit
creds="$(bw get item --organizationid "$bitwarden_org" "$repo")"
get_cred_field_value() {
    local field="$1"
    local selector="$(printf '.fields[] | select(.name == "%s") | .value' "$field")"
    jq --raw-output "$selector" <<<"$creds"
}

export LENS_BRAVE_SEARCH_API_KEY="$(get_cred_field_value "lens Brave Search")"
